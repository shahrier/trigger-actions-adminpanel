public inherited sharing class SampleAccountAction implements TriggerAction.BeforeInsert, TriggerAction.BeforeUpdate {
	
	public void beforeInsert(List<Account> newList) {
		for (Account acc : newList) {
			if (String.isBlank(acc.Description)) {
				acc.Description = 'Default description generated by Trigger Actions Framework (Before Insert).';
			}
		}
	}

	public void beforeUpdate(List<Account> newList, List<Account> oldList) {
		for (Account acc : newList) {
			if (acc.AnnualRevenue != null && acc.AnnualRevenue < 0) {
				acc.AnnualRevenue.addError('Annual Revenue cannot be negative.');
			}
		}
	}
}
