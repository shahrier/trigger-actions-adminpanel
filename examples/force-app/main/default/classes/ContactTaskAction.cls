public with sharing class ContactTaskAction implements TriggerAction.AfterInsert {
	public void afterInsert(List<Contact> newList) {
		List<Task> tasksToCreate = new List<Task>();
		for (Contact con : newList) {
			tasksToCreate.add(new Task(
				Subject = 'Welcome Call for ' + con.FirstName + ' ' + con.LastName,
				WhoId = con.Id,
				Priority = 'Normal',
				Status = 'Not Started',
				ActivityDate = Date.today().addDays(2),
				Description = 'Auto-generated by Trigger Actions Framework Examples'
			));
		}
		if (!tasksToCreate.isEmpty()) {
			insert tasksToCreate;
		}
	}
}
