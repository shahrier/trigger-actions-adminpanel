@isTest
private class SampleAccountAction_Test {
	
	@isTest
	static void testBeforeInsert() {
		Account acc = new Account(Name = 'Test Account');
		List<Account> newList = new List<Account>{acc};
		
		Test.startTest();
		new SampleAccountAction().beforeInsert(newList);
		Test.stopTest();
		
		System.assertEquals('Default description generated by Trigger Actions Framework (Before Insert).', acc.Description);
	}

	@isTest
	static void testBeforeUpdateValid() {
		Account acc = new Account(Name = 'Test Account', AnnualRevenue = 100);
		List<Account> newList = new List<Account>{acc};
		
		Test.startTest();
		new SampleAccountAction().beforeUpdate(newList, new List<Account>());
		Test.stopTest();
		
		System.assertEquals(false, acc.hasErrors());
	}

	@isTest
	static void testBeforeUpdateInvalid() {
		Account acc = new Account(Name = 'Test Account', AnnualRevenue = -50);
		List<Account> newList = new List<Account>{acc};
		
		Test.startTest();
		new SampleAccountAction().beforeUpdate(newList, new List<Account>());
		Test.stopTest();
		
		System.assertEquals(true, acc.hasErrors());
	}
}
